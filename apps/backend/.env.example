# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ai_crypto_finder
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# APIs
DEXSCREENER_API_URL=https://api.dexscreener.com
TWITTER_USERNAME=your_twitter_username
TWITTER_EMAIL=your_twitter_email
TWITTER_PASSWORD=your_twitter_password
TELEGRAM_API_ID=your_telegram_api_id
TELEGRAM_API_HASH=your_telegram_api_hash
TELEGRAM_SESSION_NAME=telegram_discovery
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
COINGECKO_API_URL=https://api.coingecko.com/api/v3
COINMARKETCAP_API_KEY=your_cmc_api_key
GMGN_API_KEY=your_gmgn_api_key

# ── Telegram Discovery ─────────────────────────────────
# Comma-separated list of Telegram groups/channels (@username or numeric ID)
# Example: TELEGRAM_GROUPS=@crypto_alpha,@solana_gems,-1001234567890
TELEGRAM_GROUPS=
TELEGRAM_DISCOVERY_TERMS=alpha,gems,lowcap,microcap,degen,moonshot,100x,1000x,calls,signals,onchain,smartmoney,whale,pumpfun,dexscreener,birdeye,gmgn,newlaunch,fairlaunch,stealthlaunch
TELEGRAM_NARRATIVE_TERMS=ai,agent,rwa,depin,gaming,privacy,prediction,memecoin,meme,l2,base,solana
TELEGRAM_DEX_DOMAINS=dexscreener.com,birdeye.so,gmgn.ai,geckoterminal.com
TELEGRAM_CHAIN_FOCUS=solana,base,ethereum,bsc
MIN_MENTIONS=5
TOP_DISCOVERY_LIMIT=100
DISCOVERY_WINDOW_MINUTES=60
TELEGRAM_STORE_RAW_TEXT=false

# Web3
RPC_URLS=ethereum:https://eth.llamarpc.com,bsc:https://bsc-dataseed.binance.org,solana:https://api.mainnet-beta.solana.com
